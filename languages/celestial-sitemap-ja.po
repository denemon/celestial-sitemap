# ── Plugin Name / Menu ──────────────────────────────────────────

msgid "Celestial Sitemap"
msgstr "Celestial Sitemap"

msgid "Celestial Sitemap — Settings"
msgstr "Celestial Sitemap — 設定"

msgid "General Settings"
msgstr "一般設定"

msgid "Settings"
msgstr "設定"

msgid "Save Settings"
msgstr "設定を保存"

msgid "Settings saved."
msgstr "設定を保存しました。"

msgid "Unauthorized"
msgstr "権限がありません"

# ── Title & Meta ────────────────────────────────────────────────

msgid "Title & Meta"
msgstr "タイトル・メタ情報"

msgid "Search engine results and browser tabs use these values. Empty fields fall back to WordPress defaults."
msgstr "検索結果やブラウザのタブに表示されます。空欄の場合は WordPress の標準設定が使われます。"

msgid "Title Separator"
msgstr "タイトル区切り文字"

msgid "Character inserted between the page title and site name (e.g. \"Page Title | Site Name\")."
msgstr "ページタイトルとサイト名の間に表示される文字です（例：「記事タイトル | サイト名」）。"

msgid "Homepage Title"
msgstr "トップページのタイトル"

msgid "Custom title tag for the front page. Leave empty to use the default WordPress title."
msgstr "トップページ専用の title タグ。空欄の場合は WordPress 標準のタイトルが使われます。"

msgid "Homepage Description"
msgstr "トップページの説明文"

msgid "Meta description for the front page. Displayed as a snippet in search results. Recommended: 120-155 characters."
msgstr "トップページの meta description。検索結果のスニペットに表示されます。推奨：120〜155文字。"

# ── Noindex ─────────────────────────────────────────────────────

msgid "Noindex Rules"
msgstr "noindex 設定"

msgid "Checked pages will have a \"noindex\" meta tag, telling search engines not to include them in results. Useful for preventing low-value pages from being indexed."
msgstr "チェックしたページには noindex メタタグが付与され、検索エンジンのインデックスから除外されます。重複コンテンツや低品質ページの除外に有効です。"

msgid "Noindex Archives"
msgstr "アーカイブを noindex"

msgid "Category & taxonomy archives"
msgstr "カテゴリー・タクソノミーのアーカイブページ"

msgid "Noindex Tags"
msgstr "タグを noindex"

msgid "Tag archives"
msgstr "タグのアーカイブページ"

msgid "Noindex Author"
msgstr "著者を noindex"

msgid "Author archives"
msgstr "著者のアーカイブページ"

msgid "Noindex Date"
msgstr "日付を noindex"

msgid "Date archives"
msgstr "日付のアーカイブページ"

msgid "Noindex Search"
msgstr "検索を noindex"

msgid "Search results"
msgstr "検索結果ページ"

# ── XML Sitemap ─────────────────────────────────────────────────

msgid "XML Sitemap"
msgstr "XML サイトマップ"

msgid "Select which content types to include in the XML sitemap submitted to search engines. News, image, and video sitemaps are generated automatically when qualifying content exists."
msgstr "検索エンジンに送信する XML サイトマップに含める投稿タイプを選択します。ニュース・画像・動画サイトマップは対象コンテンツがあれば自動生成されます。"

msgid "Post Types"
msgstr "投稿タイプ"

msgid "Taxonomies"
msgstr "タクソノミー"

msgid "View Sitemap"
msgstr "サイトマップを表示"

msgid "Flush Sitemap Cache"
msgstr "サイトマップキャッシュをクリア"

msgid "Sitemap cache cleared."
msgstr "サイトマップキャッシュをクリアしました。"

# ── Schema / Structured Data ───────────────────────────────────

msgid "Schema / Structured Data"
msgstr "構造化データ (Schema.org)"

msgid "Outputs JSON-LD structured data that helps search engines understand your site. Enables rich results (rich snippets) in Google Search."
msgstr "検索エンジンがサイト内容を理解するための JSON-LD 構造化データを出力します。Google 検索でのリッチリザルト（リッチスニペット）表示に必要です。"

msgid "Enable Schema"
msgstr "構造化データを有効化"

msgid "Output JSON-LD structured data"
msgstr "JSON-LD 構造化データを出力する"

msgid "Entity Type"
msgstr "サイト種別"

msgid "Organization (company / group)"
msgstr "組織（企業・団体）"

msgid "Person (individual)"
msgstr "個人（ブログ・ポートフォリオ）"

msgid "Choose \"Organization\" for a company or brand site, \"Person\" for a personal blog."
msgstr "企業サイトやブランドサイトの場合は「組織」を、個人ブログの場合は「個人」を選択してください。"

msgid "Name"
msgstr "名前"

msgid "Defaults to Site Title"
msgstr "サイトのタイトルを使用"

msgid "Name displayed in structured data. Leave empty to use the WordPress site title."
msgstr "構造化データに表示される名前。空欄の場合は WordPress のサイトタイトルが使われます。"

msgid "Logo URL"
msgstr "ロゴ URL"

msgid "Organization logo image URL. Leave empty to use the site icon. Not used for \"Person\" type."
msgstr "組織のロゴ画像 URL。空欄の場合はサイトアイコンが使われます。「個人」の場合は使用されません。"

msgid "Breadcrumbs"
msgstr "パンくずリスト"

msgid "Output BreadcrumbList schema"
msgstr "BreadcrumbList スキーマを出力する"

msgid "Enables breadcrumb navigation display in search results."
msgstr "検索結果にパンくずナビゲーションを表示できるようにします。"

# ── Open Graph / Social ────────────────────────────────────────

msgid "Open Graph / Social"
msgstr "OGP / SNS 連携"

msgid "Controls how your pages appear when shared on Facebook, Twitter/X, LINE, and other social platforms."
msgstr "Facebook・Twitter/X・LINE などの SNS でページがシェアされた際の表示内容を制御します。"

msgid "Enable OGP"
msgstr "OGP を有効化"

msgid "Output Open Graph meta tags"
msgstr "Open Graph メタタグを出力する"

msgid "Default OG Image"
msgstr "デフォルト OG 画像"

msgid "Fallback image used when a post has no featured image. Recommended size: 1200x630px."
msgstr "アイキャッチ画像がない投稿で使われるフォールバック画像。推奨サイズ: 1200x630px。"

msgid "Facebook App ID"
msgstr "Facebook App ID"

msgid "Optional"
msgstr "任意"

msgid "Optional. Outputs fb:app_id meta tag for Facebook Insights integration."
msgstr "任意。Facebook インサイト連携用の fb:app_id メタタグを出力します。"

msgid "Twitter/X @handle"
msgstr "Twitter/X @ユーザー名"

msgid "Your Twitter/X username. Used in twitter:site meta tag for Twitter Cards."
msgstr "Twitter/X のユーザー名。Twitter カードの twitter:site メタタグに使用されます。"

# ── Post/Term Meta Box ─────────────────────────────────────────

msgid "SEO Settings"
msgstr "SEO 設定"

msgid "SEO Title"
msgstr "SEO タイトル"

msgid "Recommended: 30-60 characters"
msgstr "推奨：30〜60文字"

msgid "Meta Description"
msgstr "メタディスクリプション"

msgid "Recommended: 120-155 characters"
msgstr "推奨：120〜155文字"

msgid "Canonical URL"
msgstr "正規 URL (canonical)"

msgid "OG Image URL"
msgstr "OG 画像 URL"

msgid "noindex this page"
msgstr "このページを noindex にする"

msgid "Tells search engines not to index this page."
msgstr "検索エンジンにこのページをインデックスしないよう指示します。"

msgid "Leave empty for auto-generated title"
msgstr "空欄で自動生成タイトルを使用"

msgid "Leave empty for auto-generated description"
msgstr "空欄で自動生成ディスクリプションを使用"

msgid "Leave empty for default"
msgstr "空欄でデフォルトを使用"

msgid "Leave empty to use featured image"
msgstr "空欄でアイキャッチ画像を使用"

# ── Taxonomy Fields ────────────────────────────────────────────

msgid "Recommended: 30-60 characters. Leave empty for auto-generated title."
msgstr "推奨：30〜60文字。空欄の場合は自動生成されます。"

msgid "Recommended: 120-155 characters. Leave empty for auto-generated description."
msgstr "推奨：120〜155文字。空欄の場合は自動生成されます。"

msgid "noindex this term"
msgstr "このタームを noindex にする"

msgid "Tells search engines not to index this term archive."
msgstr "検索エンジンにこのタームアーカイブをインデックスしないよう指示します。"

msgid "Noindex"
msgstr "noindex"

# ── Redirects ──────────────────────────────────────────────────

msgid "Redirects"
msgstr "リダイレクト"

msgid "Add Redirect"
msgstr "リダイレクトを追加"

msgid "Source URL (path)"
msgstr "リダイレクト元 URL（パス）"

msgid "Target URL"
msgstr "リダイレクト先 URL"

msgid "Status Code"
msgstr "ステータスコード"

msgid "Existing Redirects (%d)"
msgstr "登録済みリダイレクト（%d件）"

msgid "No redirects configured."
msgstr "リダイレクトは登録されていません。"

msgid "Source"
msgstr "リダイレクト元"

msgid "Target"
msgstr "リダイレクト先"

msgid "Code"
msgstr "コード"

msgid "Hits"
msgstr "ヒット数"

msgid "Updated"
msgstr "更新日時"

msgid "Action"
msgstr "操作"

msgid "Delete"
msgstr "削除"

msgid "Source and target are required."
msgstr "リダイレクト元とリダイレクト先は必須です。"

msgid "Redirect added."
msgstr "リダイレクトを追加しました。"

msgid "Failed to add redirect."
msgstr "リダイレクトの追加に失敗しました。"

msgid "Invalid regex pattern."
msgstr "正規表現パターンが無効です。"

msgid "Source and target resolve to the same URL."
msgstr "リダイレクト元とリダイレクト先が同じ URL です。"

msgid "A redirect for this source URL already exists."
msgstr "このリダイレクト元 URL は既に登録されています。"

msgid "This redirect would create a loop: the target already redirects back to the source."
msgstr "このリダイレクトはループを作成します：リダイレクト先がすでにリダイレクト元に転送されています。"

# ── 404 Log ────────────────────────────────────────────────────

msgid "404 Log"
msgstr "404 ログ"

msgid "Logged 404 Errors (%d)"
msgstr "記録された 404 エラー（%d件）"

msgid "Clear All"
msgstr "すべてクリア"

msgid "No 404 errors recorded."
msgstr "404 エラーの記録はありません。"

msgid "URL"
msgstr "URL"

msgid "Referrer"
msgstr "リファラー"

msgid "Last Seen"
msgstr "最終検出"

msgid "404 log cleared."
msgstr "404 ログをクリアしました。"

# ── Pagination ─────────────────────────────────────────────────

msgid "Previous"
msgstr "前へ"

msgid "Next"
msgstr "次へ"

msgid "Page %1$d of %2$d"
msgstr "%1$d / %2$d ページ"

# ── Conflict Detector ──────────────────────────────────────────

msgid "Celestial Sitemap: The following SEO plugin(s) are also active: %s. Running multiple SEO plugins simultaneously may cause duplicate meta tags, conflicting canonical URLs, and duplicate structured data. Consider deactivating one to avoid conflicts."
msgstr "Celestial Sitemap: 以下の SEO プラグインが同時に有効になっています: %s。複数の SEO プラグインを併用すると、メタタグの重複、canonical URL の競合、構造化データの重複が発生する可能性があります。競合を避けるため、いずれかを無効化することをお勧めします。"

# ── Schema (BreadcrumbList) ────────────────────────────────────

msgid "Home"
msgstr "ホーム"

# ── Redirect Status Codes ──────────────────────────────────────

msgid "301 — Permanent redirect"
msgstr "301 — 恒久的リダイレクト"

msgid "302 — Temporary redirect"
msgstr "302 — 一時的リダイレクト"

msgid "307 — Temporary (method preserved)"
msgstr "307 — 一時的（メソッド維持）"

msgid "308 — Permanent (method preserved)"
msgstr "308 — 恒久的（メソッド維持）"

# ── robots.txt Editor ─────────────────────────────────────────

msgid "robots.txt"
msgstr "robots.txt"

msgid "Celestial Sitemap — robots.txt Editor"
msgstr "Celestial Sitemap — robots.txt エディター"

msgid "Physical robots.txt detected"
msgstr "物理 robots.txt ファイルを検出"

msgid "A physical robots.txt file exists at %s. WordPress (and this editor) cannot override a physical file. Delete or rename the file to use this editor."
msgstr "物理 robots.txt ファイルが %s に存在します。WordPress（およびこのエディター）は物理ファイルを上書きできません。このエディターを使用するには、ファイルを削除または名前変更してください。"

msgid "The following plugins may also modify robots.txt output: %s. This could cause conflicts with your custom content."
msgstr "以下のプラグインも robots.txt の出力を変更する可能性があります: %s。カスタム内容と競合する場合があります。"

msgid "Custom robots.txt"
msgstr "カスタム robots.txt"

msgid "When enabled, this content replaces the WordPress-generated robots.txt. The sitemap URL is automatically appended if not already present."
msgstr "有効にすると、WordPress が生成する robots.txt をこの内容で置き換えます。サイトマップ URL が含まれていない場合は自動的に追記されます。"

msgid "Enable Custom robots.txt"
msgstr "カスタム robots.txt を有効化"

msgid "Use custom robots.txt content instead of WordPress default"
msgstr "WordPress 標準の代わりにカスタム robots.txt を使用する"

msgid "Content"
msgstr "内容"

msgid "Maximum %d KB. One directive per line. The sitemap URL (%s) is appended automatically if not included."
msgstr "最大 %d KB。1行に1つのディレクティブを記述してください。サイトマップ URL（%s）が含まれていない場合は自動で追記されます。"

msgid "Preview"
msgstr "プレビュー"

msgid "View Current robots.txt"
msgstr "現在の robots.txt を表示"

msgid "Opens the live robots.txt output in a new tab. Save changes first to see updates."
msgstr "現在の robots.txt 出力を新しいタブで開きます。変更を反映するには先に保存してください。"

msgid "Save robots.txt Settings"
msgstr "robots.txt 設定を保存"

msgid "robots.txt settings saved."
msgstr "robots.txt 設定を保存しました。"

msgid "robots.txt content exceeds the maximum size of %d KB."
msgstr "robots.txt の内容が最大サイズ %d KB を超えています。"

msgid "Your robots.txt does not contain \"Disallow: /wp-admin/\". Search engines may crawl your admin area."
msgstr "robots.txt に「Disallow: /wp-admin/」が含まれていません。検索エンジンが管理画面をクロールする可能性があります。"

msgid "Your robots.txt does not contain a \"User-agent:\" directive. It may not function as expected."
msgstr "robots.txt に「User-agent:」ディレクティブが含まれていません。正しく機能しない可能性があります。"
